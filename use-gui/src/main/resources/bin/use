#!/usr/bin/env bash

# Start script for USE

# CONFIGURATION
# Add -Xss20m to VMARGS when using the generator
VMARGS=""

unset CDPATH
BIN_DIR="$( cd "$( dirname "$0" )" && pwd )"
USE_HOME="$BIN_DIR/.."
USE_JAR="$USE_HOME/lib/use-gui.jar"

if [ ! -f "$USE_JAR" ]; then
	echo "Cannot find USE executable. Please provide correct path to use.jar." >&2
	exit 1
fi

export LD_LIBRARY_PATH="$USE_HOME/lib:$LD_LIBRARY_PATH"

# set cmd for running USE
# Pass -nr to suppress the "GNU readline library is not available" warning: the
# native natGNUReadline JNI lib is not shipped, so the load always fails and USE
# falls back to a simple readline implementation. The Windows launcher
# (start_use.bat) already passes -nr; this keeps the bash launcher consistent.
java $VMARGS -jar "$USE_JAR" -nr "$@"
